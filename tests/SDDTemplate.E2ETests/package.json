{
  "name": "sddtemplate-e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:browsers": "playwright install --with-deps chromium",
    "test": "playwright test",
    "test:docker": "powershell -ExecutionPolicy Bypass -File ./run-local-docker.ps1",
    "test:docker:list": "powershell -ExecutionPolicy Bypass -File ./run-local-docker.ps1 --list",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "typescript": "5.9.3"
  }
}
