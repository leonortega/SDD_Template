INSTALL_DIR=/opt/plane
PROMETHEUS_CONFIG_FILE=./prometheus.yml
DOMAIN_NAME=replace-with-plane-domain
APP_RELEASE_VERSION=v2.6.0
IS_AIRGAPPED=0

WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1
SILO_REPLICAS=1
EMAIL_REPLICAS=0
OUTBOX_POLLER_REPLICAS=1
AUTOMATION_CONSUMER_REPLICAS=1
IFRAMELY_REPLICAS=1
PI_API_REPLICAS=0
PI_BEAT_REPLICAS=0
PI_WORKER_REPLICAS=0
PI_MIGRATOR_REPLICAS=0

LISTEN_HTTP_PORT=8080
LISTEN_HTTPS_PORT=443
APP_PROTOCOL=http
TRUSTED_PROXIES=0.0.0.0/0
API_HOSTNAME=http://api:8000

CERT_EMAIL=replace-with-cert-email
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
CERT_ACME_DNS=

SITE_ADDRESS=replace-with-plane-site-address
MACHINE_SIGNATURE=replace-with-generated-machine-signature
WEB_URL=replace-with-plane-web-url
DEBUG=0
CORS_ALLOWED_ORIGINS=replace-with-cors-allowed-origins
API_BASE_URL=http://api:8000

POSTGRES_USER=plane
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=plane
PGDATA=/var/lib/postgresql/data
DATABASE_URL=
PLANE_PI_DATABASE_URL=
FOLLOWER_POSTGRES_URI=postgresql://plane:replace-with-postgres-password@plane-db/plane

REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=

RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=replace-with-rabbitmq-password
RABBITMQ_DEFAULT_VHOST=plane
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:replace-with-rabbitmq-password@plane-mq:5672/plane

OPENSEARCH_ENABLED=0
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=

SECRET_KEY=replace-with-plane-secret-key
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=replace-with-minio-access-key
AWS_SECRET_ACCESS_KEY=replace-with-minio-secret-key
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-minio-secret-key
BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880

GUNICORN_WORKERS=2
SSL_VERIFY=1
FEATURE_FLAG_SERVER_BASE_URL=http://monitor:8080
PAYMENT_SERVER_BASE_URL=http://monitor:8080

SILO_HMAC_SECRET_KEY=replace-with-silo-hmac-secret
AES_SECRET_KEY=replace-with-aes-secret
INTEGRATION_CALLBACK_BASE_URL=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_NAME=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

MINIO_ENDPOINT_SSL=0
API_KEY_RATE_LIMIT=60/minute
ENABLE_DRF_SPECTACULAR=0
LIVE_SERVER_SECRET_KEY=replace-with-live-server-secret
IFRAMELY_URL=

LISTEN_SMTP_PORT_25=10025
LISTEN_SMTP_PORT_465=10465
LISTEN_SMTP_PORT_587=10587
MAX_ATTACHMENT_SIZE=10485760
SMTP_DOMAIN=0.0.0.0
TLS_CERT_PATH=
TLS_PRIV_KEY_PATH=
INTAKE_EMAIL_DOMAIN=example.com

OUTBOX_POLLER_MEMORY_LIMIT_MB=512
OUTBOX_POLLER_INTERVAL_MIN=0.25
OUTBOX_POLLER_INTERVAL_MAX=2
OUTBOX_POLLER_BATCH_SIZE=250
OUTBOX_POLLER_MEMORY_CHECK_INTERVAL=30
OUTBOX_POLLER_POOL_SIZE=4
OUTBOX_POLLER_POOL_MIN_SIZE=2
OUTBOX_POLLER_POOL_MAX_SIZE=10
OUTBOX_POLLER_POOL_TIMEOUT=30.0
OUTBOX_POLLER_POOL_MAX_IDLE=300.0
OUTBOX_POLLER_POOL_MAX_LIFETIME=3600
OUTBOX_POLLER_POOL_RECONNECT_TIMEOUT=5.0
OUTBOX_POLLER_POOL_HEALTH_CHECK_INTERVAL=60

AUTOMATION_EVENT_STREAM_QUEUE_NAME=plane.event_stream.automations
AUTOMATION_EVENT_STREAM_PREFETCH=10
AUTOMATION_EXCHANGE_NAME=plane.event_stream
USE_STORAGE_PROXY=0

PLANE_OAUTH_REDIRECT_URI=
PLANE_OAUTH_STATE_EXPIRY_SECONDS=82800
PI_INTERNAL_SECRET=replace-with-pi-internal-secret

OPENAI_API_KEY=
OPENAI_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
GROQ_API_KEY=
GROQ_BASE_URL=
COHERE_API_KEY=
COHERE_BASE_URL=

CUSTOM_LLM_ENABLED=false
CUSTOM_LLM_MODEL_KEY=replace-with-custom-llm-model-key
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_NAME=replace-with-custom-llm-name
CUSTOM_LLM_DESCRIPTION="replace-with-custom-llm-description"
CUSTOM_LLM_MAX_TOKENS=128000

EMBEDDING_MODEL=
EMBEDDING_MODEL_ID=
BR_AWS_ACCESS_KEY_ID=
BR_AWS_SECRET_ACCESS_KEY=
BR_AWS_SESSION_TOKEN=

CELERY_VECTOR_SYNC_ENABLED=0
CELERY_VECTOR_SYNC_INTERVAL=3
CELERY_WORKSPACE_PLAN_SYNC_ENABLED=0
CELERY_WORKSPACE_PLAN_SYNC_INTERVAL=86400
CELERY_DOCS_SYNC_ENABLED=0
CELERY_DOCS_SYNC_INTERVAL=86400
