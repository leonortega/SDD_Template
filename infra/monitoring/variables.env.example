# Monitoring environment template.
#
# Copy this file to infra/monitoring/variables.env, then fill the Event Hub
# values needed by the OpenTelemetry Collector profile. Keep real values only
# in ignored .env files.

# ---------------------------------------------------------------------------
# Seq and OpenTelemetry Collector
# ---------------------------------------------------------------------------
OTELCOL_SEQ_OTLP_ENDPOINT=http://seq:5341/ingest/otlp
OTELCOL_AZURE_EVENT_HUB_DEV_CONNECTION_STRING=
OTELCOL_AZURE_EVENT_HUB_QA_CONNECTION_STRING=
OTELCOL_AZURE_EVENT_HUB_PROD_CONNECTION_STRING=
OTELCOL_AZURE_EVENT_HUB_DEV_CONSUMER_GROUP=$$Default
OTELCOL_AZURE_EVENT_HUB_QA_CONSUMER_GROUP=$$Default
OTELCOL_AZURE_EVENT_HUB_PROD_CONSUMER_GROUP=$$Default

# Rancher Desktop local-lab log capture posts sanitized Kubernetes logs to Seq.
SEQ_URL=http://localhost:5341
RANCHER_OBSERVABILITY_ENABLED=true
PROMETHEUS_URL=http://localhost:9091

# Rancher Desktop pods send live Serilog events directly to local Seq through
# the host gateway. Keep localhost for host/container scripts; use this value
# for app pods.
RANCHER_APP_SEQ_URL=http://host.docker.internal:5341

# ---------------------------------------------------------------------------
# Alerts
# ---------------------------------------------------------------------------
GRAFANA_HEALTH_ALERT_FOR=10s
SEQ_ERROR_ALERT_WINDOW=1m
SEQ_ERROR_ALERT_THRESHOLD=0

# ---------------------------------------------------------------------------
# Optional Grafana Azure Monitor datasource helper values
# ---------------------------------------------------------------------------
GRAFANA_AZURE_SUBSCRIPTION_ID=
GRAFANA_AZURE_TENANT_ID=
GRAFANA_AZURE_CLIENT_ID=
GRAFANA_AZURE_CLIENT_SECRET=
