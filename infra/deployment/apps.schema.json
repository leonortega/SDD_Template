{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deployment app topology",
  "type": "object",
  "required": [
    "version",
    "apps"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "appId",
          "projectPath",
          "role",
          "artifactName",
          "healthPath",
          "deployOrder"
        ],
        "properties": {
          "appId": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "projectPath": {
            "type": "string",
            "pattern": "^src/.+\\.csproj$"
          },
          "role": {
            "type": "string",
            "enum": [
              "web",
              "api"
            ]
          },
          "artifactName": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*\\.zip$"
          },
          "healthPath": {
            "type": "string",
            "pattern": "^/"
          },
          "deployOrder": {
            "type": "integer",
            "minimum": 0
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
