# Gitea Actions Runner Configuration
# The runner connects to Gitea over the internal Docker network
GITEA_INSTANCE_URL=http://gitea:3000
# Generate this token in Gitea: Site Admin > Actions > Runners > Create Registration Token
GITEA_RUNNER_REGISTRATION_TOKEN=replace-with-token-from-gitea
GITEA_RUNNER_NAME=local-runner
# Labels must match the runs-on values used in .gitea/workflows/*.yml
GITEA_RUNNER_LABELS=ubuntu-latest,docker,windows
# Docker network for job containers — must match Gitea's network so gitea resolves
DOCKER_NETWORK=agentic-e2e_gitea
