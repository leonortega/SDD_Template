[TEMPLATE]
GITEA_INSTANCE_URL=http://gitea:3000
GITEA_RUNNER_REGISTRATION_TOKEN=replace-with-token-from-gitea
GITEA_RUNNER_NAME=local-runner

# To generate a new registration token (replace <user> and <pass> with your Gitea admin credentials):
#   curl -s -u '<user>:<pass>' -X POST http://localhost:3000/api/v1/repos/<owner>/<repo>/actions/runners/registration-token
# Example:
#   curl -s -u 'admin:admin123' -X POST http://localhost:3000/api/v1/repos/sdd-admin/sdd-test/actions/runners/registration-token
