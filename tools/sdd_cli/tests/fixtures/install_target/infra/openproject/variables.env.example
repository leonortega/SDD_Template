# OpenProject local environment template.
#
# Copy to infra/openproject/variables.env and replace placeholder values before
# starting the local lab. Keep real values in ignored .env files only.

OPENPROJECT_TAG=17.5.1
OPENPROJECT_PORT=8080
OPENPROJECT_HOST_NAME=localhost:8080
OPENPROJECT_HTTPS=false
OPENPROJECT_DATA_DIR=./openproject

# Generate with Python or a password manager:
#   python -c "import secrets; print(secrets.token_hex(64))"
OPENPROJECT_SECRET_KEY_BASE=replace-with-generated-openproject-secret-key-base
