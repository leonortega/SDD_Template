@attribute [System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
@page "/"

<PageTitle>SDD Template</PageTitle>

<main class="landing-page">
    <section class="hero-section" aria-labelledby="hero-title">
        <div class="hero-copy">
            <p class="eyebrow">Inventory clarity for growing teams</p>
            <h1 id="hero-title">Run stock, orders, and clients from one calm dashboard.</h1>
            <p class="hero-text">
                StockPilot helps operations teams see inventory levels, low-stock risk, product movement,
                and customer demand before small gaps become expensive surprises.
            </p>
            <div class="hero-actions">
                <a class="primary-action" href="#contact">Plan a demo</a>
                <a class="secondary-action" href="/products" data-enhance-nav="false">View products</a>
            </div>
        </div>

        <div class="inventory-visual" role="img" aria-label="Inventory dashboard showing stock levels and warehouse activity">
            <div class="visual-toolbar">
                <span></span>
                <strong>Live stock board</strong>
            </div>
            <div class="stock-card urgent">
                <span>Low stock</span>
                <strong>18</strong>
            </div>
            <div class="stock-card healthy">
                <span>In warehouse</span>
                <strong>4,820</strong>
            </div>
            <div class="stock-bars" aria-hidden="true">
                <span style="--bar-width: 72%"></span>
                <span style="--bar-width: 56%"></span>
                <span style="--bar-width: 88%"></span>
                <span style="--bar-width: 42%"></span>
            </div>
        </div>
    </section>

    <section id="services" class="landing-section" aria-labelledby="services-title">
        <p class="eyebrow">Services</p>
        <h2 id="services-title">Stock management without the spreadsheet chase.</h2>
        <div class="feature-grid">
            <article>
                <h3>Inventory visibility</h3>
                <p>Track stock levels, movement, and reorder signals across teams and locations.</p>
            </article>
            <article>
                <h3>Client-ready operations</h3>
                <p>Keep client and product records close to the workflow your team already uses.</p>
            </article>
            <article>
                <h3>Actionable dashboards</h3>
                <p>Surface the next operational decision with clean summaries and clear priorities.</p>
            </article>
        </div>
    </section>

    <section id="benefits" class="landing-section split-section" aria-labelledby="benefits-title">
        <div>
            <p class="eyebrow">Benefits</p>
            <h2 id="benefits-title">Less stock anxiety. Faster decisions.</h2>
        </div>
        <ul class="benefit-list">
            <li>Spot stock-outs before orders stall.</li>
            <li>Give sales, warehouse, and finance one shared view.</li>
            <li>Move from reactive counts to planned replenishment.</li>
        </ul>
    </section>

    <section id="contact" class="contact-section" aria-labelledby="contact-title">
        <div>
            <p class="eyebrow">Contact</p>
            <h2 id="contact-title">Ready to tighten your inventory flow?</h2>
            <p>Bring your current products, clients, and stock questions. StockPilot turns them into a practical operating view.</p>
        </div>
        <a class="primary-action" href="mailto:hello@stockpilot.example">Contact StockPilot</a>
    </section>
</main>
