@page "/products"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text.Json
@attribute [System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
@inject IConfiguration Configuration
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Products</PageTitle>

<main class="products-page">
    <header class="products-header">
        <div>
            <h1>Products</h1>
            <p id="products-summary">@Summary</p>
        </div>
    </header>

    <section class="products-grid" aria-label="Product management">
        <form id="product-form" class="product-form" @onsubmit="SaveProduct">
            <input type="hidden" id="product-id" @bind="Form.Id" />

            <label>
                <span>Name</span>
                <input id="product-name" name="name" required maxlength="100" @bind="Form.Name" />
            </label>

            <label>
                <span>SKU</span>
                <input id="product-sku" name="sku" required maxlength="40" @bind="Form.Sku" />
            </label>

            <label>
                <span>Status</span>
                <select id="product-status" name="status" required @bind="Form.Status">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                    <option value="Archived">Archived</option>
                </select>
            </label>

            <label>
                <span>Price</span>
                <input id="product-price" name="price" type="number" min="0" step="0.01" required @bind="Form.Price" />
            </label>

            <label class="full-width">
                <span>Category</span>
                <input id="product-category" name="category" required maxlength="100" @bind="Form.Category" />
            </label>

            <div class="form-actions full-width">
                <button type="submit">Save product</button>
                <button type="button" id="product-reset" @onclick="ClearForm">Clear</button>
            </div>

            <p id="product-errors" class="product-errors" role="alert">@Message</p>
        </form>

        <div class="products-list-wrap">
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Status</th>
                        <th>Price</th>
                        <th>Category</th>
                        <th>Last updated</th>
                        <th><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody id="products-list">
                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="7">Loading products...</td>
                        </tr>
                    }
                    else if (ProductRows.Count == 0)
                    {
                        <tr>
                            <td colspan="7">No products exist yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (ProductModel product in ProductRows)
                        {
                            <tr>
                                <td><strong>@product.Name</strong></td>
                                <td>@product.Sku</td>
                                <td>@product.Status</td>
                                <td>@product.Price.ToString("0.00")</td>
                                <td>@product.Category</td>
                                <td>@product.LastUpdated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="row-actions">
                                    <button type="button" @onclick="() => EditProduct(product)">Edit</button>
                                    @if (PendingDeleteId == product.Id)
                                    {
                                        <button type="button" @onclick="() => ConfirmDeleteProduct(product)">Confirm delete</button>
                                    }
                                    else
                                    {
                                        <button type="button" @onclick="() => PendingDeleteId = product.Id">Delete</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>

@code {
    private List<ProductModel> ProductRows { get; set; } = [];

    private ProductModel Form { get; set; } = new();

    private string Message { get; set; } = string.Empty;

    private bool IsLoading { get; set; } = true;

    private int? PendingDeleteId { get; set; }

    private string Summary => ProductRows.Count == 1 ? "1 product" : $"{ProductRows.Count} products";

    private string ApiUrl => $"{(string.IsNullOrWhiteSpace(Configuration["Api:BaseUrl"]) ? Navigation.BaseUri : Configuration["Api:BaseUrl"])!.TrimEnd('/')}/api/products";

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        IsLoading = true;
        try
        {
            ProductRows = await HttpClientFactory.CreateClient().GetFromJsonAsync<List<ProductModel>>(ApiUrl) ?? [];
        }
        catch (Exception ex) when (ex is HttpRequestException or JsonException)
        {
            ProductRows = [];
            Message = "Products could not be loaded.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveProduct()
    {
        Message = string.Empty;
        HttpClient client = HttpClientFactory.CreateClient();
        HttpResponseMessage response = Form.Id == 0
            ? await client.PostAsJsonAsync(ApiUrl, Form)
            : await client.PutAsJsonAsync($"{ApiUrl}/{Form.Id}", Form);

        if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            Message = await ReadErrors(response);
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            Message = "The product could not be saved.";
            return;
        }

        ClearForm();
        Message = "Product saved.";
        await LoadProducts();
    }

    private void EditProduct(ProductModel product)
    {
        Form = new ProductModel(product);
        PendingDeleteId = null;
    }

    private async Task ConfirmDeleteProduct(ProductModel product)
    {
        HttpResponseMessage response = await HttpClientFactory.CreateClient().DeleteAsync($"{ApiUrl}/{product.Id}");
        if (!response.IsSuccessStatusCode)
        {
            Message = "The product could not be deleted.";
            return;
        }

        ClearForm();
        Message = "Product deleted.";
        await LoadProducts();
    }

    private void ClearForm()
    {
        Form = new ProductModel();
        PendingDeleteId = null;
    }

    private static async Task<string> ReadErrors(HttpResponseMessage response)
    {
        using JsonDocument document = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        return document.RootElement.TryGetProperty("errors", out JsonElement errors)
            ? string.Join(" ", errors.EnumerateObject().SelectMany(error => error.Value.EnumerateArray().Select(item => item.GetString())))
            : "The product could not be saved.";
    }

    private sealed class ProductModel
    {
        public ProductModel()
        {
        }

        public ProductModel(ProductModel product)
        {
            Id = product.Id;
            Name = product.Name;
            Sku = product.Sku;
            Status = product.Status;
            Price = product.Price;
            Category = product.Category;
            LastUpdated = product.LastUpdated;
        }

        public int Id { get; set; }

        public string Name { get; set; } = string.Empty;

        public string Sku { get; set; } = string.Empty;

        public string Status { get; set; } = "Active";

        public decimal Price { get; set; }

        public string Category { get; set; } = string.Empty;

        public DateTimeOffset LastUpdated { get; set; }
    }
}
