@page "/clients"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text.Json
@attribute [System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
@inject IConfiguration Configuration
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Clients</PageTitle>

<main class="clients-page">
    <header class="clients-header">
        <div>
            <h1>Clients</h1>
            <p id="clients-summary">@Summary</p>
        </div>
    </header>

    <section class="clients-grid" aria-label="Client management">
        <form id="client-form" class="client-form" onsubmit="return false">
            <input type="hidden" id="client-id" @bind="Form.Id" />

            <label>
                <span>Name</span>
                <input id="client-name" name="name" autocomplete="given-name" required maxlength="100" @bind="Form.Name" @bind:event="oninput" />
            </label>

            <label>
                <span>Last Name</span>
                <input id="client-last-name" name="lastName" autocomplete="family-name" required maxlength="100" @bind="Form.LastName" @bind:event="oninput" />
            </label>

            <label class="full-width">
                <span>Address</span>
                <input id="client-address" name="address" autocomplete="street-address" required maxlength="200" @bind="Form.Address" @bind:event="oninput" />
            </label>

            <label>
                <span>Born date</span>
                <input id="client-born-date" name="bornDate" type="date" required value="@Form.BornDate" @onchange="SetBornDate" />
            </label>

            <label>
                <span>City</span>
                <input id="client-city" name="city" autocomplete="address-level2" required maxlength="100" @bind="Form.City" @bind:event="oninput" />
            </label>

            <label>
                <span>Country</span>
                <input id="client-country" name="country" autocomplete="country-name" required maxlength="100" @bind="Form.Country" @bind:event="oninput" />
            </label>

            <label>
                <span>ZIP code</span>
                <input id="client-zip-code" name="zipCode" autocomplete="postal-code" required maxlength="12" @bind="Form.ZipCode" @bind:event="oninput" />
            </label>

            <div class="form-actions full-width">
                <button type="button" @onclick="SaveClient">Save client</button>
                <button type="button" id="client-reset" @onclick="ClearForm">Clear</button>
            </div>

            <p id="client-errors" class="client-errors" role="alert">@Errors</p>
        </form>

        <div class="clients-list-wrap">
            <table class="clients-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Born date</th>
                        <th><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody id="clients-list">
                    @if (ClientRows.Count == 0)
                    {
                        <tr>
                            <td colspan="4">No clients exist yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (ClientModel client in ClientRows)
                        {
                            <tr>
                                <td>
                                    <strong>@client.Name @client.LastName</strong>
                                    <span>@client.Address</span>
                                </td>
                                <td>
                                    @client.City, @client.Country
                                    <span>@client.ZipCode</span>
                                </td>
                                <td>@client.BornDate</td>
                                <td class="row-actions">
                                    <button type="button" @onclick="() => EditClient(client)">Edit</button>
                                    <button type="button" @onclick="() => DeleteClient(client)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>

@code {
    private List<ClientModel> ClientRows { get; set; } = [];

    private ClientModel Form { get; set; } = new();

    private string Errors { get; set; } = string.Empty;

    private string Summary => ClientRows.Count == 1 ? "1 client" : $"{ClientRows.Count} clients";

    private string ApiUrl => $"{(string.IsNullOrWhiteSpace(Configuration["Api:BaseUrl"]) ? Navigation.BaseUri : Configuration["Api:BaseUrl"])!.TrimEnd('/')}/api/clients";

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        try
        {
            ClientRows = await HttpClientFactory.CreateClient().GetFromJsonAsync<List<ClientModel>>(ApiUrl) ?? [];
        }
        catch (Exception ex) when (ex is HttpRequestException or JsonException)
        {
            ClientRows = [];
        }
    }

    private async Task SaveClient()
    {
        Errors = string.Empty;
        HttpClient client = HttpClientFactory.CreateClient();
        HttpResponseMessage response = Form.Id == 0
            ? await client.PostAsJsonAsync(ApiUrl, Form)
            : await client.PutAsJsonAsync($"{ApiUrl}/{Form.Id}", Form);

        if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            Errors = await ReadErrors(response);
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            Errors = "The client could not be saved.";
            return;
        }

        ClearForm();
        await LoadClients();
    }

    private void EditClient(ClientModel client)
    {
        Form = new ClientModel(client);
    }

    private void SetBornDate(ChangeEventArgs args)
    {
        Form.BornDate = args.Value?.ToString() ?? string.Empty;
    }

    private async Task DeleteClient(ClientModel client)
    {
        HttpResponseMessage response = await HttpClientFactory.CreateClient().DeleteAsync($"{ApiUrl}/{client.Id}");
        if (!response.IsSuccessStatusCode)
        {
            Errors = "The client could not be deleted.";
            return;
        }

        await LoadClients();
    }

    private void ClearForm()
    {
        Form = new ClientModel();
        Errors = string.Empty;
    }

    private static async Task<string> ReadErrors(HttpResponseMessage response)
    {
        using JsonDocument document = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        return document.RootElement.TryGetProperty("errors", out JsonElement errors)
            ? string.Join(" ", errors.EnumerateObject().SelectMany(error => error.Value.EnumerateArray().Select(item => item.GetString())))
            : "The client could not be saved.";
    }

    private sealed class ClientModel
    {
        public ClientModel()
        {
        }

        public ClientModel(ClientModel client)
        {
            Id = client.Id;
            Name = client.Name;
            LastName = client.LastName;
            Address = client.Address;
            BornDate = client.BornDate;
            City = client.City;
            Country = client.Country;
            ZipCode = client.ZipCode;
        }

        public int Id { get; set; }

        public string Name { get; set; } = string.Empty;

        public string LastName { get; set; } = string.Empty;

        public string Address { get; set; } = string.Empty;

        public string BornDate { get; set; } = string.Empty;

        public string City { get; set; } = string.Empty;

        public string Country { get; set; } = string.Empty;

        public string ZipCode { get; set; } = string.Empty;
    }
}
