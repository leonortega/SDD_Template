{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sdd-template/release.schema.json",
  "title": "SDD Template Release Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "commitSha",
    "checksum",
    "artifactUrl",
    "planeTicketKey",
    "versionStatus"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{7,40}$"
    },
    "checksum": {
      "type": "string",
      "minLength": 32
    },
    "artifactUrl": {
      "type": "string",
      "minLength": 1
    },
    "planeTicketKey": {
      "type": "string",
      "minLength": 1
    },
    "includedTickets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prUrl": {
      "type": "string"
    },
    "workflowRunUrl": {
      "type": "string"
    },
    "versionStatus": {
      "type": "string",
      "minLength": 1
    },
    "sourceRcVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"
    },
    "finalReleaseVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "qaEvidenceUrl": {
      "type": "string"
    },
    "qaResult": {
      "type": "string"
    },
    "dev": {
      "$ref": "#/$defs/environmentResult"
    },
    "qa": {
      "$ref": "#/$defs/environmentResult"
    },
    "prod": {
      "$ref": "#/$defs/environmentResult"
    },
    "rollback": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "environmentResult": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "url": {
          "type": "string"
        },
        "pageStatus": {
          "type": "string"
        },
        "healthStatus": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      }
    }
  }
}
