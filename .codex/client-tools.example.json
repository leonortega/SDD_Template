{
  "openProject": {
    "baseUrl": "replace-with-openproject-base-url",
    "apiToken": "replace-with-openproject-api-token",
    "projectIdentifier": "replace-with-openproject-project-identifier",
    "todoStatus": "replace-with-openproject-todo-status",
    "inProgressStatus": "replace-with-openproject-in-progress-status",
    "reviewStatus": "replace-with-openproject-review-status",
    "qaStatus": "replace-with-openproject-qa-status",
    "doneStatus": "replace-with-openproject-done-status"
  },
  "git": {
    "baseBranch": "replace-with-base-branch",
    "branchPrefix": "replace-with-branch-prefix",
    "branchPattern": "{prefix}/{ticketKeySlug}-{titleSlug}",
    "maxBranchLength": 100
  },
  "gitea": {
    "baseUrl": "replace-with-gitea-base-url",
    "apiToken": "replace-with-gitea-api-token",
    "owner": "replace-with-gitea-owner",
    "repo": "replace-with-gitea-repo"
  },
  "nexus": {
    "baseUrl": "replace-with-nexus-base-url",
    "username": "replace-with-nexus-username",
    "password": "replace-with-nexus-password-or-token",
    "repository": "replace-with-nexus-repository"
  },
  "pr": {
    "reviewers": "replace-with-reviewers",
    "minimumApprovals": {
      "dev": 1,
      "main": 1
    },
    "labels": {
      "enabled": true,
      "reviewed": "replace-with-reviewed-label",
      "needsTests": "replace-with-needs-tests-label",
      "needsChanges": "replace-with-needs-changes-label"
    }
  },
  "parallelDelivery": {
    "enabled": false,
    "maxActiveTickets": 2,
    "worktreeRoot": "../ticket-worktrees",
    "deploymentLanePolicy": "serialized",
    "agentModelPolicy": {
      "coordinator": {
        "model": "inherit",
        "reasoningEffort": "medium"
      },
      "pipelineStatus": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "low"
      },
      "ticketStarter": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "medium"
      },
      "implementation": {
        "model": "gpt-5.3-codex",
        "reasoningEffort": "medium"
      },
      "prReview": {
        "model": "gpt-5.4",
        "reasoningEffort": "high"
      },
      "postMergeDeploy": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "medium"
      },
      "deployToQa": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "medium"
      },
      "e2eQa": {
        "model": "gpt-5.4",
        "reasoningEffort": "medium"
      },
      "deployToProd": {
        "model": "gpt-5.4",
        "reasoningEffort": "high"
      },
      "fileQaBug": {
        "model": "gpt-5.4",
        "reasoningEffort": "medium"
      },
      "rollbackProd": {
        "model": "gpt-5.4",
        "reasoningEffort": "high"
      },
      "hotfixProd": {
        "model": "gpt-5.3-codex",
        "reasoningEffort": "high"
      }
    }
  },
  "recommendedTools": {
    "enabled": true,
    "mode": "guarded-auto",
    "accepted": [],
    "dismissed": []
  }
}
