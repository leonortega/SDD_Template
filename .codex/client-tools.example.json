{
  "plane": {
    "baseUrl": "replace-with-plane-base-url",
    "apiToken": "replace-with-plane-api-token",
    "workspaceSlug": "replace-with-plane-workspace-slug",
    "projectIdentifier": "replace-with-plane-project-identifier",
    "todoState": "replace-with-plane-todo-state",
    "inProgressState": "replace-with-plane-in-progress-state",
    "reviewState": "replace-with-plane-review-state",
    "qaState": "replace-with-plane-qa-state",
    "doneState": "replace-with-plane-done-state"
  },
  "git": {
    "baseBranch": "replace-with-base-branch",
    "branchPrefix": "replace-with-branch-prefix",
    "branchPattern": "{prefix}/{ticketKeySlug}-{titleSlug}",
    "maxBranchLength": 100
  },
  "gitea": {
    "baseUrl": "replace-with-gitea-base-url",
    "apiToken": "replace-with-gitea-api-token",
    "owner": "replace-with-gitea-owner",
    "repo": "replace-with-gitea-repo"
  },
  "nexus": {
    "baseUrl": "replace-with-nexus-base-url",
    "username": "replace-with-nexus-username",
    "password": "replace-with-nexus-password-or-token",
    "repository": "replace-with-nexus-repository"
  },
  "pr": {
    "reviewers": "replace-with-reviewers",
    "labels": {
      "enabled": true,
      "reviewed": "replace-with-reviewed-label",
      "needsTests": "replace-with-needs-tests-label",
      "needsChanges": "replace-with-needs-changes-label"
    }
  },
  "parallelDelivery": {
    "enabled": false,
    "maxActiveTickets": 2,
    "worktreeRoot": "../ticket-worktrees",
    "deploymentLanePolicy": "serialized",
    "agentModelPolicy": {
      "coordinator": {
        "model": "inherit",
        "reasoningEffort": "medium"
      },
      "pipelineStatus": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "low"
      },
      "ticketStarter": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "medium"
      },
      "implementation": {
        "model": "gpt-5.3-codex",
        "reasoningEffort": "medium"
      },
      "prReview": {
        "model": "gpt-5.4",
        "reasoningEffort": "high"
      },
      "postMergeDeploy": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "medium"
      },
      "deployToQa": {
        "model": "gpt-5.4-mini",
        "reasoningEffort": "medium"
      },
      "e2eQa": {
        "model": "gpt-5.4",
        "reasoningEffort": "medium"
      },
      "deployToProd": {
        "model": "gpt-5.4",
        "reasoningEffort": "high"
      },
      "fileQaBug": {
        "model": "gpt-5.4",
        "reasoningEffort": "medium"
      },
      "rollbackProd": {
        "model": "gpt-5.4",
        "reasoningEffort": "high"
      },
      "hotfixProd": {
        "model": "gpt-5.3-codex",
        "reasoningEffort": "high"
      }
    }
  },
  "recommendedTools": {
    "enabled": true,
    "mode": "guided-manual",
    "accepted": [],
    "dismissed": []
  }
}
